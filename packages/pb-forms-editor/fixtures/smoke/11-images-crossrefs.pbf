Global Img_FrmImages_2

Enumeration FormWindow
  #FrmImages
EndEnumeration

Enumeration FormGadget
  #ImgPreview
  #BtnApply
EndEnumeration

Enumeration FormMenu
  #MenuOpen
  #TbSave
EndEnumeration

Enumeration FormImage
  #Img_FrmImages_0
  #Img_FrmImages_1
  #Img_FrmImages_3
EndEnumeration

UsePNGImageDecoder()

LoadImage(#Img_FrmImages_0,"open.png")
LoadImage(#Img_FrmImages_1,"./icons/apply.png")
Img_FrmImages_2 = LoadImage(#PB_Any,"save.png")
CatchImage(#Img_FrmImages_3,?Img_FrmImages_3)


Procedure OpenFrmImages(x = 0, y = 0, width = 320, height = 180)
  OpenWindow(#FrmImages, x, y, width, height, "Images")
  CreateToolBar(0, WindowID(#FrmImages))
  ToolBarImageButton(#TbSave,ImageID(Img_FrmImages_2))
  ToolBarToolTip(0, #TbSave, "Save")
  CreateStatusBar(0, WindowID(#FrmImages))
  AddStatusBarField(#PB_Ignore)
  StatusBarImage(0, 0, ImageID(#Img_FrmImages_3))
  CreateImageMenu(0, WindowID(#FrmImages))
  MenuTitle("Open")
  ImageGadget(#ImgPreview, 10, ToolBarHeight(0) + 10, 32, 32, ImageID(#Img_FrmImages_0))
  ButtonImageGadget(#BtnApply, 52, ToolBarHeight(0) + 10, 96, 28, ImageID(#Img_FrmImages_1))
EndProcedure



DataSection
  Img_FrmImages_3: : IncludeBinary ""
EndDataSection
