; Warning: this file uses a strict syntax, if you edit it, make sure to respect the Form Designer limitation or it won't be opened again.

;
; This code is automatically generated by the Form Designer.
; Manual modification is possible to adjust existing commands, but anything else will be dropped when the code is compiled.
; Event procedures need to be put in another source file.
;

Global imgSave

Enumeration FormWindow
  #FrmImages
EndEnumeration

Enumeration FormGadget
  #ImgPreview
  #BtnApply
EndEnumeration

Enumeration FormMenu
  #MenuOpen
  #TbSave
EndEnumeration

Enumeration FormImage
  #ImgOpen
  #ImgRelative
  #ImgState
EndEnumeration

UsePNGImageDecoder()

LoadImage(#ImgOpen, "open.png")
LoadImage(#ImgRelative, "./icons/apply.png")
imgSave = LoadImage(#PB_Any, "save.png")
CatchImage(#ImgState, ?ImgState)


Procedure OpenFrmImages(x = 0, y = 0, width = 320, height = 180)
  OpenWindow(#FrmImages, x, y, width, height, "Images")
  CreateToolbar(0, WindowID(#FrmImages))
  ToolBarImageButton(#TbSave, ImageID(imgSave))
  ToolBarToolTip(0, #TbSave, "Save")
  CreateStatusBar(0, WindowID(#FrmImages))
  AddStatusBarField(#PB_Ignore)
  StatusBarImage(0, 0, ImageID(#ImgState))
  CreateImageMenu(0, WindowID(#FrmImages))
  MenuTitle("Open")
  MenuItem(#MenuOpen, "Open", ImageID(#ImgOpen))
  ImageGadget(#ImgPreview, 10, ToolBarHeight(0) + 10, 32, 32, ImageID(#ImgOpen))
  ButtonImageGadget(#BtnApply, 52, ToolBarHeight(0) + 10, 96, 28, ImageID(#ImgRelative), #PB_Button_Default)
EndProcedure



DataSection
  ImgState: : IncludeBinary ""
EndDataSection
