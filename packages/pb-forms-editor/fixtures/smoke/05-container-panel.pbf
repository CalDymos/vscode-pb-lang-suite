Enumeration FormWindow
  #FrmPanelHost
EndEnumeration

Enumeration FormGadget
  #PnlMain
  #TxtTab0
  #StrTab1
  #BtnTab2
EndEnumeration


Procedure OpenFrmPanelHost(x = 0, y = 0, width = 360, height = 220)
  OpenWindow(#FrmPanelHost, x, y, width, height, "Panel Host", #PB_Window_SystemMenu)
  PanelGadget(#PnlMain, 10, 10, 320, 180)
  AddGadgetItem(#PnlMain, -1, "General")
  TextGadget(#TxtTab0, 15, 20, 120, 20, "Tab0")
  AddGadgetItem(#PnlMain, -1, "Advanced")
  StringGadget(#StrTab1, 15, 20, 120, 25, "Tab1")
  AddGadgetItem(#PnlMain, -1, "Third")
  ButtonGadget(#BtnTab2, 15, 20, 100, 24, "Tab2")
  CloseGadgetList()
EndProcedure

