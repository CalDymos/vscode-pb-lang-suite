Enumeration FormWindow
  #FrmStyleProps
EndEnumeration

Enumeration FormGadget
  #TxtName
  #ChkActive
EndEnumeration

Enumeration FormFont
  #Font_FrmStyleProps_0
EndEnumeration

LoadFont(#Font_FrmStyleProps_0,"Arial", 12, #PB_Font_Bold | #PB_Font_Italic)


Procedure OpenFrmStyleProps(x = 0, y = 0, width = 320, height = 180)
  OpenWindow(#FrmStyleProps, x, y, width, height, "Style Props")
  StringGadget(#TxtName, 10, 10, 180, 24, Value$)
  HideGadget(#TxtName, 1)
  GadgetToolTip(#TxtName, Tooltip$)
  SetGadgetColor(#TxtName, #PB_Gadget_FrontColor,RGB(51,34,17))
  SetGadgetColor(#TxtName, #PB_Gadget_BackColor,RGB(10,20,30))
  SetGadgetFont(#TxtName, FontID(#Font_FrmStyleProps_0))
  CheckBoxGadget(#ChkActive, 10, 46, 120, 20, "Active")
  SetGadgetState(#ChkActive, #PB_Checkbox_Checked)
EndProcedure

