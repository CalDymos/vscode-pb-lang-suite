Enumeration FormWindow
  #FrmMain
EndEnumeration

Enumeration FormImage
  #Img_FrmMain_0
EndEnumeration

UsePNGImageDecoder()

LoadImage(#Img_FrmMain_0,"icons/state.png")


Procedure OpenFrmMain(x = 0, y = 0, width = 320, height = 220)
  OpenWindow(#FrmMain, x, y, width, height, "StatusBar")
  CreateStatusBar(0, WindowID(#FrmMain))
  AddStatusBarField(120)
  StatusBarText(0, 0, "Ready", #PB_StatusBar_Center)
  AddStatusBarField(90)
  StatusBarProgress(0, 1, 0, #PB_StatusBar_Raised)
  AddStatusBarField(#PB_Ignore)
  StatusBarImage(0, 2, ImageID(#Img_FrmMain_0), #PB_StatusBar_BorderLess)
EndProcedure

