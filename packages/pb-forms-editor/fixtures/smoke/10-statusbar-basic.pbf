Enumeration FormWindow
  #FrmMain
EndEnumeration

Enumeration FormGadget
EndEnumeration

Procedure OpenFrmMain()
  LoadImage(#ImgState, "icons/state.png")
  OpenWindow(#FrmMain, 0, 0, 320, 220, "StatusBar")
  CreateStatusBar(#SbMain, WindowID(#FrmMain))
  AddStatusBarField(120)
  AddStatusBarField(90)
  AddStatusBarField(#PB_Ignore)
  StatusBarText(#SbMain, 0, "Ready", #PB_StatusBar_Center)
  StatusBarProgress(#SbMain, 1, 35, #PB_StatusBar_Raised)
  StatusBarImage(#SbMain, 2, ImageID(#ImgState), #PB_StatusBar_BorderLess)
EndProcedure
