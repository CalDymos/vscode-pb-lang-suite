Enumeration FormWindow
  #FrmSplit
EndEnumeration

Enumeration FormGadget
  #TxtLeft
  #TxtRight
  #SplitMain
EndEnumeration


Procedure OpenFrmSplit(x = 0, y = 0, width = 320, height = 220)
  OpenWindow(#FrmSplit, x, y, width, height, "Splitter", #PB_Window_SystemMenu)
  StringGadget(#TxtLeft, 10, 40, 84, 120, "Left")
  StringGadget(#TxtRight, 101, 40, 159, 120, Value$)
  SplitterGadget(#SplitMain, 10, 40, 250, 120, #TxtLeft, #TxtRight, #PB_Splitter_Vertical)
  SetGadgetState(#SplitMain, 112)
EndProcedure

