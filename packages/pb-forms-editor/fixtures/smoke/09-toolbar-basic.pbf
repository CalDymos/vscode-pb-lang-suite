Enumeration FormWindow
  #FrmMain
EndEnumeration

Enumeration FormGadget
EndEnumeration

Procedure OpenFrmMain()
  LoadImage(#ImgSave, "icons/save.png")
  OpenWindow(#FrmMain, 0, 0, 320, 220, "Toolbar")
  CreateToolBar(#TbMain, WindowID(#FrmMain))
  ToolBarStandardButton(#PB_ToolBarIcon_New, #PB_ToolBarIcon_New)
  ToolBarImageButton(#TbSave, ImageID(#ImgSave), #PB_ToolBar_Toggle)
  ToolBarToolTip(#TbMain, #TbSave, "Save current form")
  ToolBarSeparator()
EndProcedure
