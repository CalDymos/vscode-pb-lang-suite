Enumeration FormWindow
  #FrmObjectEvents
EndEnumeration

Enumeration FormGadget
  #BtnApply
EndEnumeration

Enumeration FormMenu
  #MenuOpen
  #TbRefresh
EndEnumeration

Enumeration FormImage
  #Img_FrmObjectEvents_0
EndEnumeration

UsePNGImageDecoder()

LoadImage(#Img_FrmObjectEvents_0,"toolbar-refresh.png")

Declare HandleToolbarRefresh(Event)
Declare HandleMenuOpen(Event)
Declare HandleApply(EventType)

Procedure OpenFrmObjectEvents(x = 0, y = 0, width = 320, height = 220)
  OpenWindow(#FrmObjectEvents, x, y, width, height, "Object Events")
  CreateToolbar(0, WindowID(#FrmObjectEvents))
  ToolBarImageButton(#TbRefresh,ImageID(#Img_FrmObjectEvents_0))
  CreateMenu(0, WindowID(#FrmObjectEvents))
  MenuTitle("Open")
  MenuItem(#MenuOpen, "Open")
  ButtonGadget(#BtnApply, 10, ToolBarHeight(0) + 10, 90, 25, "Apply")
EndProcedure

Procedure FrmObjectEvents_Events(event)
  Select event
    Case #PB_Event_CloseWindow
      ProcedureReturn #False

    Case #PB_Event_Menu
      Select EventMenu()
        Case #MenuOpen
          HandleMenuOpen(EventMenu())
        Case #TbRefresh
          HandleToolbarRefresh(EventMenu())
      EndSelect

    Case #PB_Event_Gadget
      Select EventGadget()
        Case #BtnApply
          HandleApply(EventType())          
      EndSelect
  EndSelect
  ProcedureReturn #True
EndProcedure

