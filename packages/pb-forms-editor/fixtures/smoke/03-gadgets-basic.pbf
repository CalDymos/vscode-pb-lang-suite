Global gInput

Enumeration FormWindow
  #FrmGadgets
EndEnumeration

Enumeration FormGadget
  #LblName
  #BtnOk
EndEnumeration


Procedure OpenFrmGadgets(x = 0, y = 0, width = 320, height = 180)
  OpenWindow(#FrmGadgets, x, y, width, height, "Gadgets Basic")
  TextGadget(#LblName, 10, 10, 120, 20, "Name")
  gInput = StringGadget(#PB_Any, 10, 36, 220, 24, "")
  ButtonGadget(#BtnOk, 10, 70, 90, 26, "OK")
EndProcedure

