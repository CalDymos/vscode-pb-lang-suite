Enumeration FormWindow
  #FrmMain
EndEnumeration

Enumeration FormGadget
EndEnumeration

Procedure OpenFrmMain()
  LoadImage(#ImgOpen, "icons/open.png")
  OpenWindow(#FrmMain, 0, 0, 320, 220, "Menu")
  CreateMenu(#MenuMain, WindowID(#FrmMain))
  MenuTitle("File")
  MenuItem(#MenuOpen, "Open""Ctrl+O", ImageID(#ImgOpen))
  MenuBar()
  OpenSubMenu("Recent")
  MenuItem(#MenuRecent1, "Last file")
  CloseSubMenu()
EndProcedure
