Enumeration FormWindow
  #FrmMain
EndEnumeration

Enumeration FormMenu
  #MenuOpen
  #MenuRecent1
EndEnumeration

Enumeration FormImage
  #Img_FrmMain_0
EndEnumeration

UsePNGImageDecoder()

LoadImage(#Img_FrmMain_0,"icons/open.png")


Procedure OpenFrmMain(x = 0, y = 0, width = 320, height = 220)
  OpenWindow(#FrmMain, x, y, width, height, "Menu")
  AddKeyboardShortcut(#FrmMain, #PB_Shortcut_Control | #PB_Shortcut_O, #MenuOpen)

  CreateImageMenu(0, WindowID(#FrmMain))
  MenuTitle("File")
  MenuItem(#MenuOpen, "Open" + Chr(9) + "Ctrl+O", ImageID(#Img_FrmMain_0))
  MenuBar()
  OpenSubMenu("Recent")
  MenuItem(#MenuRecent1, "Last file")
  CloseSubMenu()
EndProcedure

