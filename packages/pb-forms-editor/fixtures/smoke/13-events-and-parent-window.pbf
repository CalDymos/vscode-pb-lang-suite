Enumeration FormWindow
  #FrmEventsParent
EndEnumeration

Declare HandleFrmEventsParent(Event, Window)

XIncludeFile "events/form-events.pbi"

Procedure OpenFrmEventsParent(x = 0, y = 0, width = 280, height = 170)
  OpenWindow(#FrmEventsParent, x, y, width, height, "Events Parent", #PB_Window_SystemMenu | #PB_Window_SizeGadget | #PB_Window_CustomTag, WindowID(#ParentWin))
EndProcedure

Procedure FrmEventsParent_Events(event)
  Select event
    Case #PB_Event_CloseWindow
      ProcedureReturn #False

    Case #PB_Event_Menu
      Select EventMenu()
      EndSelect

    Case #PB_Event_Gadget
      Select EventGadget()
      EndSelect
    Default
      HandleFrmEventsParent(event,#FrmEventsParent)
  EndSelect
  ProcedureReturn #True
EndProcedure

