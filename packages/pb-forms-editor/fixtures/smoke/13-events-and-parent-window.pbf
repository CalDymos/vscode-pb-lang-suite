Enumeration FormWindow
  #FrmEventsParent
EndEnumeration

Enumeration FormGadget
EndEnumeration

XIncludeFile "events/form-events.pbi"

Procedure OpenFrmEventsParent(x = 0, y = 0, width = 280, height = 170)
  OpenWindow(#FrmEventsParent, x, y, width, height, "Events Parent", #PB_Window_SystemMenu | #PB_Window_SizeGadget | #PB_Window_CustomTag, WindowID(#ParentWin))
  Select EventGadget()
    Default
      HandleFrmEventsParent()
  EndSelect
EndProcedure
