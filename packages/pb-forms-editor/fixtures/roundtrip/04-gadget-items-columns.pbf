Enumeration FormWindow
  #FrmItemsCols
EndEnumeration

Enumeration FormGadget
  #ListUsers
EndEnumeration


Procedure OpenFrmItemsCols(x = 0, y = 0, width = 360, height = 220)
  OpenWindow(#FrmItemsCols, x, y, width, height, "Items Columns")
  ListIconGadget(#ListUsers, 10, 10, 320, 140, "Name", 120)
  AddGadgetColumn(#ListUsers, 1, "Role", 100)
  AddGadgetItem(#ListUsers, -1, "Alice")
  AddGadgetItem(#ListUsers, -1, "Bob")
EndProcedure

