Enumeration FormWindow
  #FrmCombined
EndEnumeration

Enumeration FormGadget
EndEnumeration

#MenuMain = 100
#MnuOpen = 101
#MnuSave = 102
#TbMain = 200
#TbRefresh = 201
#TbSync = 202
#SbMain = 300

Procedure OpenFrmCombined(x = 0, y = 0, width = 380, height = 220)
  OpenWindow(#FrmCombined, x, y, width, height, "Combined Regression")

  CreateMenu(#MenuMain, WindowID(#FrmCombined))
  MenuTitle("File")
  MenuItem(#MnuOpen, "Open")
  MenuBar()

  CreateToolBar(#TbMain, WindowID(#FrmCombined))
  ToolBarButton(#TbRefresh, 0, "Refresh")
  ToolBarToolTip(#TbRefresh, "Refresh data")

  CreateStatusBar(#SbMain, WindowID(#FrmCombined))
  AddStatusBarField(120)
EndProcedure
