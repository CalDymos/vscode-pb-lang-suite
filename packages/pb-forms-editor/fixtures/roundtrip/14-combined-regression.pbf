; Form Designer for PureBasic - 6.30
; Warning: this file uses a strict syntax, if you edit it, make sure to respect the Form Designer limitation or it won't be opened again.

;
; This code is automatically generated by the Form Designer.
; Manual modification is possible to adjust existing commands, but anything else will be dropped when the code is compiled.
; Event procedures need to be put in another source file.
;

Enumeration FormWindow
  #FrmMain
EndEnumeration

Enumeration FormMenu
  #MnuOpen
  #TbSave
EndEnumeration

Enumeration FormImage
  #ImgOpen
  #ImgSave
  #ImgState
EndEnumeration

UsePNGImageDecoder()

LoadImage(#ImgOpen, "open.png")
LoadImage(#ImgSave, "save.png")
CatchImage(#ImgState, ?ImgState)


Procedure OpenFrmMain(x = 0, y = 0, width = 380, height = 220)
  OpenWindow(#FrmMain, x, y, width, height, "Combined Regression")
  CreateStatusBar(0, WindowID(#FrmMain))
  AddStatusBarField(120)
  StatusBarText(0, 0, "Ready", #PB_StatusBar_Center)
  AddStatusBarField(90)
  StatusBarProgress(0, 1, 35, #PB_StatusBar_Raised)
  AddStatusBarField(#PB_Ignore)
  StatusBarImage(0, 2, ImageID(#ImgState), #PB_StatusBar_BorderLess)
  CreateToolbar(0, WindowID(#FrmMain))
  ToolBarImageButton(#TbSave, ImageID(#ImgSave))
  ToolBarToolTip(0, #TbSave, "Save current form")
  ToolBarSeparator()
  CreateImageMenu(0, WindowID(#FrmMain))
  MenuTitle("File")
  MenuItem(#MnuOpen, "Open" + Chr(9) + "Ctrl+O", ImageID(#ImgOpen))
  MenuBar()
EndProcedure



DataSection
  ImgState: : IncludeBinary ""
EndDataSection
