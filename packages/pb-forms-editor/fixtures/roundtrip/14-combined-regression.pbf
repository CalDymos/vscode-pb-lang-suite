Enumeration FormWindow
  #FrmCombined
EndEnumeration

Enumeration FormMenu
  #MnuOpen
EndEnumeration


Procedure OpenFrmCombined(x = 0, y = 0, width = 380, height = 220)
  OpenWindow(#FrmCombined, x, y, width, height, "Combined Regression")
  CreateStatusBar(0, WindowID(#FrmCombined))
  AddStatusBarField(120)
  CreateMenu(0, WindowID(#FrmCombined))
  MenuTitle("File")
  MenuItem(#MnuOpen, "Open")
  MenuBar()
EndProcedure

