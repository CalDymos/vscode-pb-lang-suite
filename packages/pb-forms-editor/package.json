{
  "name": "pb-forms-editor",
  "displayName": "PureBasic Forms Editor",
  "description": "Custom Editor for PureBasic .pbf forms with a webview designer.",
  "version": "0.13.0",
  "publisher": "CalDymos",
  "author": {
    "name": "CalDymos"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/CalDymos/vscode-pb-lang-suite.git",
    "directory": "packages/pb-forms-editor"
  },
  "bugs": {
    "url": "https://github.com/CalDymos/vscode-pb-lang-suite/issues"
  },
  "homepage": "https://github.com/CalDymos/vscode-pb-lang-suite/tree/main/packages/pb-forms-editor",
  "license": "MIT",
  "keywords": [
    "purebasic",
    "pbf",
    "forms",
    "form designer",
    "forms editor",
    "gui",
    "gui designer",
    "ui designer",
    "visual designer",
    "custom editor",
    "webview",
    "rad",
    "dialog",
    "window",
    "gadgets"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:purebasic.formDesigner"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "purebasic.formDesigner",
        "displayName": "PureBasic Form Designer",
        "selector": [
          {
            "filenamePattern": "*.pbf"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "purebasic.formDesigner.openAsText",
        "title": "%purebasicFormsDesigner.command.openAsText%",
        "icon": "icons/application_view_text.png"
      },
      {
        "command": "purebasic.formDesigner.openInDesigner",
        "title": "%purebasicFormsDesigner.command.openInDesigner%",
        "icon": "icons/application_view_form.png"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "purebasic.formDesigner.openAsText",
          "when": "resourceExtname == .pbf",
          "group": "navigation@50"
        },
        {
          "command": "purebasic.formDesigner.openInDesigner",
          "when": "resourceExtname == .pbf",
          "group": "navigation@51"
        }
      ],
      "editor/context": [
        {
          "command": "purebasic.formDesigner.openAsText",
          "when": "resourceExtname == .pbf && activeCustomEditorId == 'purebasic.formDesigner'",
          "group": "navigation@50"
        },
        {
          "command": "purebasic.formDesigner.openInDesigner",
          "when": "resourceExtname == .pbf && activeCustomEditorId != 'purebasic.formDesigner'",
          "group": "navigation@51"
        }
      ],
      "editor/title": [
        {
          "command": "purebasic.formDesigner.openAsText",
          "when": "resourceExtname == .pbf && activeCustomEditorId == 'purebasic.formDesigner'",
          "group": "navigation@50"
        },
        {
          "command": "purebasic.formDesigner.openInDesigner",
          "when": "resourceExtname == .pbf && activeCustomEditorId != 'purebasic.formDesigner'",
          "group": "navigation@51"
        }
      ]
    },
    "configuration": {
      "title": "%purebasicFormsDesigner.configurationTitle%",
      "properties": {
        "purebasicFormsDesigner.showGrid": {
          "type": "boolean",
          "default": true,
          "description": "%purebasicFormsDesigner.showGrid.description%"
        },
        "purebasicFormsDesigner.gridMode": {
          "type": "string",
          "enum": [
            "dots",
            "lines"
          ],
          "default": "dots",
          "description": "%purebasicFormsDesigner.gridMode.description%"
        },
        "purebasicFormsDesigner.gridSize": {
          "type": "number",
          "default": 5,
          "minimum": 2,
          "maximum": 100,
          "description": "%purebasicFormsDesigner.gridSize.description%"
        },
        "purebasicFormsDesigner.gridOpacity": {
          "type": "number",
          "default": 0.14,
          "minimum": 0.02,
          "maximum": 0.5,
          "description": "%purebasicFormsDesigner.gridOpacity.description%"
        },
        "purebasicFormsDesigner.snapToGrid": {
          "type": "boolean",
          "default": false,
          "description": "%purebasicFormsDesigner.snapToGrid.description%"
        },
        "purebasicFormsDesigner.windowFillOpacity": {
          "type": "number",
          "default": 0.05,
          "minimum": 0,
          "maximum": 0.25,
          "description": "%purebasicFormsDesigner.windowFillOpacity.description%"
        },
        "purebasicFormsDesigner.canvasBackground": {
          "type": "string",
          "default": "",
          "description": "%purebasicFormsDesigner.canvasBackground.description%"
        },
        "purebasicFormsDesigner.canvasReadonlyBackground": {
          "type": "string",
          "default": "",
          "description": "%purebasicFormsDesigner.canvasReadonlyBackground.description%"
        },
        "purebasicFormsDesigner.snapMode": {
          "type": "string",
          "enum": [
            "live",
            "drop"
          ],
          "default": "drop",
          "description": "%purebasicFormsDesigner.snapMode.description%"
        },
        "purebasicFormsDesigner.outsideDimOpacity": {
          "type": "number",
          "default": 0.12,
          "minimum": 0,
          "maximum": 0.35,
          "description": "%purebasicFormsDesigner.outsideDimOpacity.description%"
        },
        "purebasicFormsDesigner.titleBarHeight": {
          "type": "number",
          "default": 26,
          "minimum": 0,
          "maximum": 60,
          "description": "%purebasicFormsDesigner.titleBarHeight.description%"
        },
        "purebasicFormsDesigner.windowPreviewWindowsCaptionlessTopPadding": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "maximum": 60,
          "description": "%purebasicFormsDesigner.windowPreviewWindowsCaptionlessTopPadding.description%"
        },
        "purebasicFormsDesigner.windowPreviewWindowsClientSidePadding": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "maximum": 60,
          "description": "%purebasicFormsDesigner.windowPreviewWindowsClientSidePadding.description%"
        },
        "purebasicFormsDesigner.windowPreviewWindowsClientBottomPadding": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "maximum": 60,
          "description": "%purebasicFormsDesigner.windowPreviewWindowsClientBottomPadding.description%"
        },
        "purebasicFormsDesigner.expectedPbVersion": {
          "type": "string",
          "default": "",
          "description": "%purebasicFormsDesigner.expectedPbVersion.description%"
        },
        "purebasicFormsDesigner.newGadgetsUsePbAnyByDefault": {
          "type": "boolean",
          "default": true,
          "description": "%purebasicFormsDesigner.newGadgetsUsePbAnyByDefault.description%"
        },
        "purebasicFormsDesigner.newGadgetsUseVariableAsCaption": {
          "type": "boolean",
          "default": false,
          "description": "%purebasicFormsDesigner.newGadgetsUseVariableAsCaption.description%"
        },
        "purebasicFormsDesigner.generateEventProcedure": {
          "type": "boolean",
          "default": true,
          "description": "%purebasicFormsDesigner.generateEventProcedure.description%"
        },
        "purebasicFormsDesigner.osSkin": {
          "type": "string",
          "enum": [
            "windows7",
            "windows8",
            "linux",
            "macos"
          ],
          "enumDescriptions": [
            "%purebasicFormsDesigner.osSkin.windows7%",
            "%purebasicFormsDesigner.osSkin.windows8%",
            "%purebasicFormsDesigner.osSkin.linux%",
            "%purebasicFormsDesigner.osSkin.macos%"
          ],
          "default": "windows7",
          "description": "%purebasicFormsDesigner.osSkin.description%"
        },
        "purebasicFormsDesigner.warningUnrecognizedFile": {
          "type": "string",
          "enum": [
            "never",
            "always"
          ],
          "enumDescriptions": [
            "%purebasicFormsDesigner.warningMode.never%",
            "%purebasicFormsDesigner.warningMode.always%"
          ],
          "default": "always",
          "description": "%purebasicFormsDesigner.warningUnrecognizedFile.description%"
        },
        "purebasicFormsDesigner.warningVersionUpgrade": {
          "type": "string",
          "enum": [
            "never",
            "ifBackwardCompatibilityIsAffected",
            "always"
          ],
          "enumDescriptions": [
            "%purebasicFormsDesigner.warningMode.never%",
            "%purebasicFormsDesigner.warningMode.ifBackwardCompatibilityIsAffected%",
            "%purebasicFormsDesigner.warningMode.always%"
          ],
          "default": "ifBackwardCompatibilityIsAffected",
          "description": "%purebasicFormsDesigner.warningVersionUpgrade.description%"
        },
        "purebasicFormsDesigner.warningVersionDowngrade": {
          "type": "string",
          "enum": [
            "never",
            "always"
          ],
          "enumDescriptions": [
            "%purebasicFormsDesigner.warningMode.never%",
            "%purebasicFormsDesigner.warningMode.always%"
          ],
          "default": "always",
          "description": "%purebasicFormsDesigner.warningVersionDowngrade.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack --mode development --config webpack.config.js",
    "watch": "webpack --mode development --watch --config webpack.config.js",
    "webpack:prod": "webpack --mode production --config webpack.config.js",
    "vscode:prepublish": "npm run webpack:prod",
    "compile:test": "tsc -p ./tsconfig.test.json && node ./test/scripts/copy-vscode-shim.js",
    "compile:webview": "tsc -p ./tsconfig.webview.json",
    "test": "npm run compile:test && node --test out-test/test/*.test.js",
    "test:watch": "npm run compile:test && node --test --watch out-test/test/parser.smoke.test.js out-test/test/patch.window-gadget.test.js out-test/test/patch.items-columns.test.js out-test/test/patch.combined.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1",
    "ts-loader": "^9.5.4",
    "source-map-loader": "^5.0.0"
  }
}
